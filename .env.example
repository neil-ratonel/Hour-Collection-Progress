# Snowflake (same credentials as your other dashboards)
SNOWFLAKE_ACCOUNT=your_org-account
SNOWFLAKE_USER=your_email_or_login
SNOWFLAKE_ROLE=YOUR_ROLE
SNOWFLAKE_PAT=
# SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=YOUR_WH
SNOWFLAKE_DATABASE=PRODDB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_AUTHENTICATOR=snowflake

# Slack — webhook URL (preferred) or bot token
SLACK_WEBHOOK_URL=https://hooks.slack.com/triggers/...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C0123456789

# Scheduler — cron expression (ET) for automatic Slack push
# Default: every Monday at 9:00 AM ET
SCHEDULE_CRON=0 9 * * 1
TIMEZONE=America/Toronto
